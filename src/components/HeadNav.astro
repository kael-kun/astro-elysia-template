---
import Container from './ui/Container.astro';
import Button from './ui/Button.astro';
import Text from './base/Text.astro';


interface Props {
  logo?: string;
  name?: string;
}
const { logo = "Logo", name = "Loading... " } = Astro.props;

const dropdownId = `dropdown-nav`;
---

<script is:inline>
  function toggleDropdown(id) {
    const dropdown = document.getElementById(id);
    dropdown.classList.toggle('hidden');
  }

  function closeDropdown(event, id) {
    const dropdown = document.getElementById(id);
    const button = dropdown.previousElementSibling;
    if (!dropdown.contains(event.target) && event.target !== button) {
      dropdown.classList.add('hidden');
    }
  }

  document.addEventListener('click', (event) => {
    const dropdowns = document.querySelectorAll('[data-dropdown]');
    dropdowns.forEach(dropdown => {
      const button = dropdown.previousElementSibling;
      if (!dropdown.contains(event.target) && !button.contains(event.target)) {
        dropdown.classList.add('hidden');
      }
    });
  });
</script>

<header class="border-b border-neutral-200 dark:border-neutral-800 bg-white dark:bg-neutral-900">
  <Container size="full">
    <nav class="flex items-center justify-between py-4">
      <a href="/" class="text-xl font-semibold text-neutral-900 dark:text-white hover:text-neutral-600 dark:hover:text-neutral-300 transition-colors">
        {logo}
      </a>
      
      <div class="relative">
        <button 
          onclick={`toggleDropdown('${dropdownId}')`}
          class="flex items-center gap-2 px-3 py-2 cursor-pointer text-sm font-medium text-neutral-700 dark:text-neutral-200 hover:bg-neutral-100 dark:hover:bg-neutral-800 rounded-lg transition-colors"
        >
          <span id="profile-name" data-default={name}>{name}</span>
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
          </svg>
        </button>
        
        <div 
          id={dropdownId}
          data-dropdown
          class="hidden absolute right-0 mt-2 w-56 bg-white dark:bg-neutral-800 rounded-xl shadow-lg border border-neutral-200 dark:border-neutral-700 py-2 z-50"
        >
          <div class="px-4 py-2 border-b border-neutral-200 dark:border-neutral-700">
            <Text variant="small" class="text-neutral-500 dark:text-neutral-400">Signed in as</Text>
            <p id="profile-email" data-default={name} class="text-sm font-medium text-neutral-900 dark:text-white">{name}</p>
          </div>
          <div class="px-4 py-2">
            <Button id="logout-btn" variant="primary" class="w-full">Logout</Button>
          </div>
        </div>
      </div>
    </nav>
  </Container>
</header>

<script>
  import { authStore } from "../lib/authStore";
  import { logout } from "./auth/hooks/useAuth";
  



  const profile = await authStore.getProfile();
  const profileName = document.getElementById("profile-name") as HTMLParagraphElement;
  const profileEmail = document.getElementById("profile-email") as HTMLParagraphElement;
  
  if (profile) {
    profileName.textContent = profile.name;
    profileEmail.textContent = profile.email;
  }
  
  const logoutBtn = document.getElementById("logout-btn") as HTMLButtonElement;
  logoutBtn.addEventListener("click", async () => {
    await logout();
    location.reload();
  });

</script>